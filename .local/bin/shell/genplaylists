#!/usr/bin/python3
from io import StringIO
import os
import argparse
from pathlib import Path

parser = argparse.ArgumentParser(description='Generates .m3u by folder')
parser.add_argument('d', help='Music folder')
args = parser.parse_args()

MUSIC_DIR = Path(args.d)
PLAYLIST_DIR = MUSIC_DIR / './PLAYLISTS'
FILE_EXT = ('mp3', 'flac')

assert os.path.exists(MUSIC_DIR)
assert os.path.exists(PLAYLIST_DIR)


def subwalk(top):
    for root, dirs, files in os.walk(top):
        yield from (Path(os.path.relpath(root, PLAYLIST_DIR)) / f for f in files if f.endswith(FILE_EXT))


def rootlist():
    for d in next(os.walk(MUSIC_DIR))[1]:
        subdir = MUSIC_DIR / d
        yield [d, subwalk(subdir)]


def main():
    for band, songs in rootlist():
        written = 0
        content = StringIO()
        filepath = PLAYLIST_DIR / f'{band}.m3u'

        written += content.write('#EXTM3U\n')
        for song in songs:
            written += content.write(str(song) + '\n')

        print(f'{written} -> {filepath}')
        with open(filepath, 'w') as f:
            f.write(content.getvalue())

main()

